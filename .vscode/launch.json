{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Launch 01_03_mcp_native",
      "program": "${workspaceFolder}/01_03_mcp_native/app.js",
      "cwd": "${workspaceFolder}/01_03_mcp_native",
      "console": "integratedTerminal",
      "runtimeExecutable": "node",
      "env": {},
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Launch 01_05_agent (bun)",
      "program": "${workspaceFolder}/01_05_agent/src/index.ts",
      "cwd": "${workspaceFolder}/01_05_agent",
      "console": "integratedTerminal",
      "runtimeExecutable": "bun",
      "env": {},
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "pwa-node",
      "request": "attach",
      "name": "Attach to Bun (Inspector)",
      "port": 9229,
      "address": "localhost",
      "cwd": "${workspaceFolder}/01_05_agent",
      "localRoot": "${workspaceFolder}/01_05_agent",
      "remoteRoot": "${workspaceFolder}/01_05_agent",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Launch 01_05_agent (tsx)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "tsx", "src/index.ts"],
      "cwd": "${workspaceFolder}/01_05_agent",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Launch 03_01_evals (tsx)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "tsx", "--env-file=.env", "src/index.ts"],
      "cwd": "${workspaceFolder}/03_01_evals",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "bun",
      "request": "launch",
      "name": "Launch 03_01_evals (bun)",
      "program": "${workspaceFolder}/03_01_evals/src/index.ts",
      "cwd": "${workspaceFolder}/03_01_evals",
      "console": "integratedTerminal",
      "stopOnEntry": false,
      "env": {},
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
